<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Blog Web App</title>
  </head>
  <body>
    <%- include("./partials/header.ejs") %> 
    <main>
        <% if(locals.currentPage == "Home") {%>
            <%- include("home.ejs") %>
        <% }else if (locals.currentPage == "Contact"){%>        
            <%- include("contact.ejs") %>
        <% }else if (locals.currentPage == "Posts"){%>        
            <%- include("myposts.ejs") %>
        <% }else{ %>
            <h1>Page Not Found</h1>
        <% } %>
    </main>
    <%- include("./partials/footer.ejs")%>
  </body>
</html>
